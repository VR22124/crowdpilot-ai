VITE_FIREBASE_API_KEY=your_api_key
VITE_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=1234567890
VITE_FIREBASE_APP_ID=1:1234567890:web:abcdef123456
VITE_FIREBASE_MEASUREMENT_ID=G-XXXXXXXXXX
VITE_FIREBASE_DATABASE_URL=https://your_project-default-rtdb.firebaseio.com
VITE_FIREBASE_VAPID_KEY=your_web_push_vapid_public_key
VITE_FIREBASE_APP_CHECK_SITE_KEY=recaptcha_site_key
VITE_GEMINI_API_KEY=your_gemini_api_key
VITE_GEMINI_MODEL=gemini-2.5-flash
VITE_TFLITE_MODEL_URL=/models/crowdpilot_micro_model.tflite
VITE_FIREBASE_FUNCTIONS_REGION=us-central1

VITE_PREDICTION_FUNCTION_NAME=predictCrowdState
VITE_PREDICTION_FUNCTION_URL=https://us-central1-your_project.cloudfunctions.net/predictCrowdState
VITE_CLOUD_RUN_SIMULATION_URL=https://your-cloud-run-service-xxxxx-uc.a.run.app
VITE_ENABLE_CLOUD_FUNCTIONS=false
VITE_ENABLE_TINY_LOCAL_ML=true
VITE_ENABLE_WEB_PUSH_MESSAGING=false

VITE_ENABLE_REALTIME_FALLBACK=true
VITE_ENABLE_DEV_METRICS_PANEL=true
